{
        "schemaVersion": 1,
        "id": "rays-mod",
        "version": "${version}",
        "name": "Rays Farms",
        "description": "Rays Farms — a farming helper mod by ArSi.",
        "authors": [
                "ArSi"
        ],
        "contact": {
                "homepage": "https://fabricmc.net/",
                "sources": "https://github.com/FabricMC/fabric-example-mod"
        },
        "license": "CC0-1.0",
        "icon": "assets/rays-mod/icon.png",
        "environment": "*",
        "entrypoints": {
                "main": [
                        "net.arsija.RaysMod"
                ],
                "client": [
                        "net.arsija.client.RaysModClient"
                ]
        },
        "mixins": [
                "rays-mod.mixins.json",
                {
                        "config": "rays-mod.client.mixins.json",
                        "environment": "client"
                }
        ],
        "depends": {
                "fabricloader": ">=0.19.2",
                "minecraft": "~26.1.2",
                "java": ">=25",
                "fabric-api": "*"
        }
}
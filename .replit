modules = ["java-graalvm22.3"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build mod"

[[workflows.workflow]]
name = "Build mod"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "JAVA_HOME=$PWD/.local/jdk25/jdk-25.0.3 PATH=$PWD/.local/jdk25/jdk-25.0.3/bin:$PATH ./gradlew build --no-daemon --console=plain"
